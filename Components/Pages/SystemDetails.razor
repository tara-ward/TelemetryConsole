@page "/systems/{id:int}"
@using TardisTelemetryConsole.Models
@using TardisTelemetryConsole.Services
@inject TelemetryService TelemetryService

<PageTitle>System Diagnostics</PageTitle>

<section class="tardis-page">
    @if (_subsystem is null)
    {
        <article class="tardis-card">
            <header class="tardis-card-header">
                System Not Found
            </header>
            <div class="p-3">
                <p class="mb-3">
                    The requested subsystem could not be located. It may have been removed or the identifier is invalid.
                </p>
                <a class="console-button text-decoration-none" href="/">
                    Back to Dashboard
                </a>
            </div>
        </article>
    }
    else
    {
        <header class="tardis-header">
            <h1 class="mb-1">@_subsystem.Name</h1>
            <p class="mb-2">@_subsystem.Description</p>
            <span class="status-pill @GetStatusClass(_subsystem.Status)">
                @_subsystem.Status
            </span>
        </header>

        <article class="tardis-card mb-3">
            <header class="tardis-card-header">
                Sensor Readings
            </header>
            <div class="reading-grid">
                @foreach (var reading in _subsystem.Readings)
                {
                    <div class="reading-tile">
                        <div class="fw-semibold">@reading.Name</div>
                        <div>@reading.Value.ToString("0.0") @reading.Unit</div>
                        <small>Updated: @reading.LastUpdated.ToLocalTime().ToString("g")</small>
                    </div>
                }
            </div>
        </article>

        <section class="alert-panel">
            <h2 class="h5 mb-3">Subsystem Alerts</h2>
            @if (_subsystem.Alerts.Count == 0)
            {
                <div class="alert-item">
                    No active alerts for this subsystem.
                </div>
            }
            else
            {
                @foreach (var alert in _subsystem.Alerts)
                {
                    <div class="alert-item @GetAlertClass(alert.Severity)">
                        <strong>@alert.Severity</strong> - @alert.Message
                    </div>
                }
            }
        </section>

        <div class="mt-3">
            <a class="console-button text-decoration-none" href="/">
                Back to Dashboard
            </a>
        </div>
    }
</section>

@code {
    [Parameter]
    public int Id { get; set; }

    private TardisSubsystem? _subsystem;

    protected override void OnParametersSet()
    {
        _subsystem = TelemetryService.GetSubsystemById(Id);
    }

    private static string GetStatusClass(string status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "status-stable";
        }

        if (status.Contains("critical", StringComparison.OrdinalIgnoreCase))
        {
            return "status-critical";
        }

        if (status.Contains("warning", StringComparison.OrdinalIgnoreCase))
        {
            return "status-warning";
        }

        return "status-stable";
    }

    private static string GetAlertClass(string severity)
    {
        if (severity.Equals("Critical", StringComparison.OrdinalIgnoreCase))
        {
            return "alert-item-critical";
        }

        if (severity.Equals("Warning", StringComparison.OrdinalIgnoreCase))
        {
            return "alert-item-warning";
        }

        return string.Empty;
    }
}
